{
  "name": "@mg/tailwind-config",
  "version": "0.2.0",
  "publishConfig": {
    "registry": "https://npmjs.bluettipower.com/",
    "access": "restricted"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./preset": {
      "types": "./dist/preset.d.ts",
      "import": "./dist/preset.mjs",
      "require": "./dist/preset.js"
    },
    "./base.css": "./src/base.css"
  },
  "files": [
    "dist",
    "src/base.css"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "@mg/tsconfig": "workspace:*",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "tailwindcss": "^4.0.0",
    "rimraf": "^6.0.0"
  }
}
