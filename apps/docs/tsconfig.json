{
  "extends": "@mg/tsconfig/nextjs.json",
  "compilerOptions": {
    "declaration": false,
    "declarationMap": false,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@/lib/*": [
        "./src/lib/*"
      ],
      "@/.source": [
        ".source"
      ]
    },
    "incremental": true
  },
  "include": [
    "next-env.d.ts",
    "source.config.ts",
    "src",
    ".source",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next"
  ]
}
